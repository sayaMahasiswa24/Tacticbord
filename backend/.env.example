# ════════════════════════════════════════════════════════
#  Salin file ini menjadi .env dan isi nilai sebenarnya.
#  JANGAN PERNAH commit file .env ke GitHub!
# ════════════════════════════════════════════════════════

# Wajib — API key Anthropic milikmu, disimpan aman di server
# (bukan di browser). Dapatkan di https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port server backend
PORT=8787

# Domain frontend React kamu (untuk CORS). Gunakan koma untuk lebih dari satu.
# Contoh: https://tacticbord.vercel.app,https://tacticbord.netlify.app
# Pakai "*" hanya untuk testing lokal — JANGAN pakai "*" di production.
CORS_ORIGIN=http://localhost:5173

# Lokasi file database SQLite (dibiarkan default saat pakai Docker)
DATA_DIR=./data
